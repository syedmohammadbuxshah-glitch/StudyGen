# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this in your deployment provider environment variables.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Optional: set this to your GitHub Pages or custom deployment URL when needed.
# Example: https://your-github-username.github.io/StudyGen/
APP_URL="https://your-github-username.github.io/StudyGen/"
